{
  "kind": "collectionType",
  "collectionName": "doc_pages",
  "info": {
    "singularName": "doc-page",
    "pluralName": "doc-pages",
    "displayName": "Doc Page",
    "description": "A documentation page (Welcome, Overview, Variables, Components, etc.)."
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "maxLength": 160
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "excerpt": {
      "type": "text",
      "maxLength": 400
    },
    "coverImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "order": {
      "type": "integer",
      "default": 0,
      "required": true
    },
    "section": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::section.section",
      "inversedBy": "docPages"
    },
    "blocks": {
      "type": "dynamiczone",
      "components": [
        "shared.hero",
        "shared.section-heading",
        "shared.rich-text",
        "shared.callout",
        "shared.code-block",
        "shared.image",
        "shared.feature-grid"
      ]
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo"
    }
  }
}
