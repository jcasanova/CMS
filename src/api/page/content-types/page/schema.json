{
  "kind": "collectionType",
  "collectionName": "pages",
  "info": {
    "singularName": "page",
    "pluralName": "pages",
    "displayName": "Page",
    "description": "A page of the website, composed of flexible content blocks."
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "maxLength": 160
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "blocks": {
      "type": "dynamiczone",
      "components": [
        "shared.hero",
        "shared.section-heading",
        "shared.rich-text",
        "shared.callout",
        "shared.code-block",
        "shared.image",
        "shared.feature-grid",
        "shared.decision-tree",
        "shared.theme-preview",
        "shared.icon-grid"
      ]
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo"
    }
  }
}
