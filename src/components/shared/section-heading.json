{
  "collectionName": "components_shared_section_headings",
  "info": {
    "displayName": "Section Heading",
    "icon": "bold",
    "description": "A titled section break with optional eyebrow and subheading."
  },
  "options": {},
  "attributes": {
    "eyebrow": {
      "type": "string",
      "maxLength": 60
    },
    "heading": {
      "type": "string",
      "required": true,
      "maxLength": 140
    },
    "subheading": {
      "type": "text",
      "maxLength": 400
    },
    "align": {
      "type": "enumeration",
      "enum": [
        "left",
        "center"
      ],
      "default": "left"
    }
  }
}
